---
import DocsLayout from '../../layouts/DocsLayout.astro';
import DocsSidebar from '../../components/DocsSidebar.astro';
import MarkdownViewer from '../../components/MarkdownViewer.astro';
import { marked } from 'marked';
import fs from 'fs/promises';
import path from 'path';

export async function getStaticPaths() {
  const docsDir = path.join(process.cwd(), 'docs');
  const files = await fs.readdir(docsDir);
  const mdFiles = files.filter(f => f.endsWith('.md'));
  
  const paths = [];
  for (const file of mdFiles) {
    const slug = file.replace('.md', '');
    paths.push({
      params: { slug },
      props: { slug }
    });
  }
  
  return paths;
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;

const docsManifestPath = path.join(process.cwd(), 'docs', 'docs-manifest.json');
let docsManifest = [];
try {
  const manifestContent = await fs.readFile(docsManifestPath, 'utf-8');
  docsManifest = JSON.parse(manifestContent);
} catch (e) {
  docsManifest = [{ id: 'vision', title: 'Vision' }];
}

const docPath = path.join(process.cwd(), 'docs', `${slug}.md`);
let content = '# Document Not Found';
let title = slug;

try {
  const mdContent = await fs.readFile(docPath, 'utf-8');
  content = marked(mdContent) as string;
  
  const firstLine = mdContent.split('\n')[0];
  if (firstLine.startsWith('# ')) {
    title = firstLine.substring(2);
  }
} catch (e) {
  content = `# Error\n\nDocument "${slug}" not found.`;
}

const docs = docsManifest.map((d: any) => ({
  id: d.id || d.slug,
  title: d.title,
  path: `/docs/${d.id || d.slug}`
}));
---

<DocsLayout title={title}>
  <div class="app-container">
    <DocsSidebar docs={docs} currentDoc={slug} />
    
    <main class="main-content">
      <button class="menu-toggle" aria-label="Toggle menu">☰</button>
      
      <article>
        <MarkdownViewer content={content} />
      </article>
    </main>
  </div>

  <script>
    const menuToggle = document.querySelector('.menu-toggle');
    const sidebar = document.querySelector('.sidebar');
    const closeBtn = document.querySelector('.close-btn');

    menuToggle?.addEventListener('click', () => {
      sidebar?.classList.add('open');
    });

    closeBtn?.addEventListener('click', () => {
      sidebar?.classList.remove('open');
    });
  </script>
</DocsLayout>

<style>
  .app-container {
    display: flex;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
    margin-left: 0;
    padding: 2rem;
  }

  @media (min-width: 768px) {
    .main-content {
      margin-left: 280px;
    }
  }

  .menu-toggle {
    display: block;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 999;
    background: #3498db;
    color: #fff;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 1.5rem;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .menu-toggle {
      display: none;
    }
  }

  article {
    max-width: 900px;
    margin: 0 auto;
  }
</style>
