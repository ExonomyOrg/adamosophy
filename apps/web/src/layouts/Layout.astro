---
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="description" content={Astro.props.description || 'Adamosophy - Social Wisdom Through Technology'} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<title>{Astro.props.title}</title>
</head>
<body>
<div class="app-grid">
<TopNav />
<aside class="sidebar">
<Sidebar />
</aside>
<main class="main-content">
<slot />
</main>
<footer class="footer">
<p>&copy; 2026 Adamosophy. All rights reserved. | Build: <script>document.write(new Date().toISOString())</script></p>
</footer>
</div>
</body>
</html>
