---
import TopNav from '../components/TopNav.astro';
import { getDocs } from '../lib/docs';
import '../styles/global.css';

const docItems = await getDocs();
---

<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="description" content={Astro.props.description || 'Adamosophy - Social Wisdom Through Technology'} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<title>{Astro.props.title}</title>
</head>
<body>
<div class="app-grid">
<TopNav />
<aside class="sidebar">
<div class="sidebar-section">
<h3 class="sidebar-heading">Documentation</h3>
<ul class="sidebar-list">
{docItems.map((doc) => (
<li class="sidebar-item">
<a href={`/adamosophy/docs/${doc.slug}`} class="sidebar-link">{doc.title}</a>
</li>
))}
</ul>
</div>
</aside>
<main class="main-content">
<slot />
</main>
<footer class="footer">
<p>&copy; 2026 Adamosophy. All rights reserved.</p>
</footer>
</div>
</body>
</html>
