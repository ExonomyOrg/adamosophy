---
import TopNav from '../components/TopNav.astro';
import { getDocs } from '../lib/docs';

const { title = 'Adamosophy' } = Astro.props;
const docs = await getDocs();
const currentSlug = Astro.url.pathname.split('/').pop() || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Social wisdom through technology for created humankind" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <TopNav title={title} />

    <div class="layout">
      <aside class="sidebar">
        <nav>
          <ul>
            {docs.map((doc) => (
              <li>
                <a 
                  href={`/adamosophy/docs/${doc.slug}`} 
                  class:list={{ active: doc.slug === currentSlug }}
                >
                  {doc.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  :global(*) {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :global(body) {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    color: #424242;
    background: #fafafa;
    line-height: 1.6;
  }

  .layout {
    display: flex;
    min-height: 100vh;
    padding-top: 64px;
  }

  .sidebar {
    width: 280px;
    background: #f5f5f5;
    border-right: 1px solid #e0e0e0;
    padding: 1.5rem;
    position: fixed;
    top: 64px;
    left: 0;
    bottom: 0;
    overflow-y: auto;
  }

  .sidebar nav ul {
    list-style: none;
  }

  .sidebar nav li {
    margin-bottom: 0.5rem;
  }

  .sidebar nav a {
    display: block;
    padding: 0.75rem 1rem;
    color: #424242;
    text-decoration: none;
    border-radius: 6px;
    transition: background-color 0.2s;
  }

  .sidebar nav a:hover {
    background: #e8e8e8;
  }

  .sidebar nav a.active {
    background: #1976d2;
    color: white;
    font-weight: 500;
  }

  .content {
    flex: 1;
    margin-left: 280px;
    padding: 2rem 3rem;
    max-width: 100%;
    overflow-x: hidden;
  }

  @media (max-width: 1023px) {
    .content {
      margin-left: 0;
      padding: 1.5rem;
    }
  }
</style>
