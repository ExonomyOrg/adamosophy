---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Adamosophy - Social Wisdom Through Technology">
  <div class="main-content-inner">
    <section class="hero">
      <h1>Adamosophy</h1>
      <p class="tagline">Social wisdom through technology for created humankind</p>
      <p class="subtitle">A showroom of decentralized applications for autonomous civilization</p>
      <div class="hero-links">
        <a href="/adamosophy/docs/vision" class="btn btn-secondary">Read Documentation</a>
      </div>
    </section>

    <section class="apps-grid">
      <h2>Applications</h2>
      <div class="card-grid">
        <article class="card">
          <h3 class="card-title">Republet</h3>
          <p class="card-description">Autonomous scientific publication platform enabling peer review and dissemination without centralized authorities.</p>
          <div class="tech-stack">
            <span class="badge">Willow</span>
            <span class="badge">Exonomy</span>
          </div>
          <div class="card-action">
            <a href="/adamosophy/republet" class="btn">Explore</a>
          </div>
        </article>

        <article class="card">
          <h3 class="card-title">InterNovel</h3>
          <p class="card-description">Collaborative creative writing environment where communities co-author narratives in real-time.</p>
          <div class="tech-stack">
            <span class="badge">Willow</span>
            <span class="badge">Exonomy</span>
          </div>
          <div class="card-action">
            <a href="/adamosophy/novel" class="btn">Explore</a>
          </div>
        </article>

        <article class="card featured">
          <h3 class="card-title">Exonomy</h3>
          <p class="card-description">Self-sovereign economics system for creating and transacting with community vouchers.</p>
          <div class="tech-stack">
            <span class="badge">Willow</span>
            <span class="badge highlight">Voucher Minting</span>
          </div>
          <div class="card-action">
            <a href="/adamosophy/exonomy" class="btn">Explore</a>
          </div>
        </article>

        <article class="card">
          <h3 class="card-title">Homo Judaicus</h3>
          <p class="card-description">A manifesto for understanding self-organizing human collectives, presented through the InterNovel viewer.</p>
          <div class="tech-stack">
            <span class="badge">InterNovel</span>
            <span class="badge">InViewer</span>
          </div>
          <div class="card-action">
            <a href="/adamosophy/hj" class="btn">Read Manifesto</a>
          </div>
        </article>
      </div>
    </section>

    <section class="shared-tech">
      <h2>Shared Technologies</h2>
      <div class="card-grid">
        <div class="card">
          <h3 class="card-title">Willow / Earthstar</h3>
          <p class="card-description">Decentralized networking and information sharing layer powering all applications.</p>
        </div>
        <div class="card">
          <h3 class="card-title">Exonomy Vouchers</h3>
          <p class="card-description">Self-sovereign economic tokens for value exchange across the ecosystem.</p>
        </div>
        <div class="card">
          <h3 class="card-title">InViewer</h3>
          <p class="card-description">PDF-style document viewer for presenting InterNovel creations.</p>
        </div>
      </div>
    </section>

    <section class="monorepo-info card">
      <h2 class="card-title">Built as a Monorepo</h2>
      <p class="card-description">This ecosystem is managed with <strong>Turborepo</strong>, ensuring shared code stays synchronized while each application maintains independence.</p>
      <ul class="tech-list">
        <li><strong>packages/willow</strong> - Shared networking layer</li>
        <li><strong>packages/vouchers</strong> - Voucher verification & spending (minting exclusive to Exonomy)</li>
        <li><strong>packages/ui</strong> - Shared UI components</li>
        <li><strong>packages/inviewer</strong> - Document viewer component</li>
      </ul>
    </section>
  </div>
</Layout>

<style>
  .main-content-inner {
    display: grid;
    gap: var(--grid-gap-lg);
  }

  .hero {
    text-align: center;
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: var(--space-sm);
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary, #00ACC1));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    font-size: 1rem;
    color: var(--color-text-muted, #9E9E9E);
  }

  .apps-grid h2,
  .shared-tech h2,
  .monorepo-info h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
  }

  .tech-stack {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }

  .badge {
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: var(--space-xs) var(--space-sm);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .badge.highlight {
    background: var(--color-primary);
    color: white;
  }

  .btn-secondary {
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    margin-left: var(--space-md);
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
  }

  .hero-links {
    margin-top: var(--space-lg);
  }

  .monorepo-info ul {
    list-style: none;
    padding: 0;
    margin-top: var(--space-md);
  }

  .monorepo-info li {
    padding: var(--space-sm) 0;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .monorepo-info li:last-child {
    border-bottom: none;
  }

  .monorepo-info strong {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .tagline {
      font-size: 1.1rem;
    }
  }
</style>
