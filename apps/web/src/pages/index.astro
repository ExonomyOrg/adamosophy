---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Adamosophy - Decentralized Apps for Humanity">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container hero-content">
      <h1 class="hero-title">Decentralized Apps for Humanity</h1>
      <p class="hero-subtitle">
        A curated showroom of sovereign applications designed to empower individuals, 
        foster community, and restore digital autonomy.
      </p>
      <div class="hero-cta">
        <a href="#featured" class="btn btn-primary">Explore the Ecosystem</a>
        <a href="/adamosophy/docs/vision" class="btn btn-secondary">Read Our Vision</a>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="mission-section">
    <div class="container">
      <div class="section-header">
        <h2>Our Mission</h2>
        <p>Building a future where technology serves human flourishing</p>
      </div>
      <div class="mission-grid">
        <div class="mission-card">
          <div class="mission-icon">🛡️</div>
          <h3>Sovereignty</h3>
          <p>Tools that return control of data, identity, and assets to individuals.</p>
        </div>
        <div class="mission-card">
          <div class="mission-icon">🔗</div>
          <h3>Interoperability</h3>
          <p>Systems designed to work together, breaking down silos and fostering connection.</p>
        </div>
        <div class="mission-card">
          <div class="mission-icon">🤝</div>
          <h3>Community</h3>
          <p>Platforms that prioritize human relationships over extraction and engagement metrics.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section id="featured" class="features-section">
    <div class="container">
      <div class="section-header">
        <h2>Featured Projects</h2>
        <p>Explore our growing ecosystem of decentralized applications</p>
      </div>
      <div class="features-grid">
        <!-- Republet -->
        <article class="feature-card">
          <div class="card-header">
            <span class="card-icon">📰</span>
            <h3>Republet</h3>
          </div>
          <p class="card-description">
            A decentralized publishing platform empowering writers and readers with true ownership 
            of content and curation.
          </p>
          <a href="/adamosophy/republet" class="card-link">Learn More →</a>
        </article>

        <!-- InterNovel -->
        <article class="feature-card">
          <div class="card-header">
            <span class="card-icon">📖</span>
            <h3>InterNovel</h3>
          </div>
          <p class="card-description">
            Collaborative storytelling reimagined. Create, share, and evolve narratives together 
            in a decentralized literary universe.
          </p>
          <a href="/adamosophy/novel" class="card-link">Learn More →</a>
        </article>

        <!-- Exonomy -->
        <article class="feature-card">
          <div class="card-header">
            <span class="card-icon">💹</span>
            <h3>Exonomy</h3>
          </div>
          <p class="card-description">
            An economic system explorer visualizing alternative models of exchange, value, 
            and resource allocation beyond traditional capitalism.
          </p>
          <a href="/adamosophy/exonomy" class="card-link">Learn More →</a>
        </article>

        <!-- Homo Judaicus -->
        <article class="feature-card">
          <div class="card-header">
            <span class="card-icon">🕎</span>
            <h3>Homo Judaicus</h3>
          </div>
          <p class="card-description">
            A digital space for exploring Jewish heritage, identity, and thought in the 
            modern decentralized age.
          </p>
          <a href="/adamosophy/hj" class="card-link">Learn More →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="steps-section">
    <div class="container">
      <div class="section-header">
        <h2>How It Works</h2>
        <p>Join the movement in three simple steps</p>
      </div>
      <div class="steps-grid">
        <div class="step-item">
          <div class="step-number">1</div>
          <h3>Explore</h3>
          <p>Browse our curated collection of decentralized applications.</p>
        </div>
        <div class="step-item">
          <div class="step-number">2</div>
          <h3>Engage</h3>
          <p>Try out apps that resonate with your values and needs.</p>
        </div>
        <div class="step-item">
          <div class="step-number">3</div>
          <h3>Contribute</h3>
          <p>Join communities, provide feedback, or build your own app.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container cta-content">
      <h2>Ready to Reclaim Your Digital Sovereignty?</h2>
      <p>Start exploring the future of decentralized applications today.</p>
      <a href="#featured" class="btn btn-primary btn-large">Get Started</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <h3>Adamosophy</h3>
        <p>Showcasing decentralized applications for humanity.</p>
      </div>
      
      <div class="footer-links">
        <h4>Projects</h4>
        <ul>
          <li><a href="/adamosophy/republet">Republet</a></li>
          <li><a href="/adamosophy/novel">InterNovel</a></li>
          <li><a href="/adamosophy/exonomy">Exonomy</a></li>
          <li><a href="/adamosophy/hj">Homo Judaicus</a></li>
        </ul>
      </div>
      
      <div class="footer-links">
        <h4>Resources</h4>
        <ul>
          <li><a href="/adamosophy/docs/vision">Vision Document</a></li>
          <li><a href="https://github.com/thalperi/adamosophy" target="_blank">GitHub</a></li>
          <li><a href="/adamosophy/docs">Documentation</a></li>
        </ul>
      </div>
      
      <div class="footer-links">
        <h4>Connect</h4>
        <ul>
          <li><a href="#">Twitter</a></li>
          <li><a href="#">Discord</a></li>
          <li><a href="#">Newsletter</a></li>
        </ul>
      </div>
    </div>
    
    <div class="container footer-bottom">
      <p>&copy; 2026 Adamosophy. Built for humanity.</p>
    </div>
  </footer>
</Layout>
